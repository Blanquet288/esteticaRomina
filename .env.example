# Copia este archivo a ".env" y completa los valores.
# Luego ejecuta: npm install && npm run config
#
# Las claves web de Firebase son públicas en el cliente; aun así,
# conviene no versionarlas y restringir dominio en la consola de Firebase.

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
